            DataInfo   interface{} `json:"dataInfo"`=20
        } `json:"result"`
    }

    var respData Response
    if err :=3D json.Unmarshal(body, &amp;respData); err !=3D nil {
        fmt.Printf("Error unmarshaling response: %v\n", err)
        return
    }

    for i, res :=3D range respData.Result.OcrResults {

        if res.OcrImage !=3D nil {
            imgBytes, err :=3D base64.StdEncoding.DecodeString(*res.OcrImag=
e)
            if err !=3D nil {
                fmt.Printf("Error decoding image %d: %v\n", i, err)
                continue
            }

            filename :=3D fmt.Sprintf("ocr_%d.jpg", i)
            if err :=3D ioutil.WriteFile(filename, imgBytes, 0644); err !=
=3D nil {
                fmt.Printf("Error saving image %s: %v\n", filename, err)
                continue
            }
            fmt.Printf("Output image saved at %s\n", filename)
        }
