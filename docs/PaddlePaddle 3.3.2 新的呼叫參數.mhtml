    auto response =3D client.Post("/ocr", jsonObj.dump(), "application/json=
");

    if (response &amp;&amp; response-&gt;status =3D=3D 200) {
        nlohmann::json jsonResponse =3D nlohmann::json::parse(response-&gt;=
