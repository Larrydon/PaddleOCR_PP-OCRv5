)

func main() {
    API_URL :=3D "http://localhost:8080/ocr"
    filePath :=3D "./demo.jpg"

    fileBytes, err :=3D ioutil.ReadFile(filePath)
    if err !=3D nil {
        fmt.Printf("Error reading file: %v\n", err)
        return
    }
    fileData :=3D base64.StdEncoding.EncodeToString(fileBytes)

    payload :=3D map[string]interface{}{
        "file":     fileData,
        "fileType": 1,
    }
    payloadBytes, err :=3D json.Marshal(payload)
    if err !=3D nil {
        fmt.Printf("Error marshaling payload: %v\n", err)
        return
    }

    client :=3D &amp;http.Client{}
    req, err :=3D http.NewRequest("POST", API_URL, bytes.NewBuffer(payloadB=
ytes))
    if err !=3D nil {
        fmt.Printf("Error creating request: %v\n", err)
        return
    }
    req.Header.Set("Content-Type", "application/json")

    res, err :=3D client.Do(req)
    if err !=3D nil {
        fmt.Printf("Error sending request: %v\n", err)
        return
    }
    defer res.Body.Close()

    if res.StatusCode !=3D http.StatusOK {
        fmt.Printf("Unexpected status code: %d\n", res.StatusCode)
        return
    }

    body, err :=3D ioutil.ReadAll(res.Body)
    if err !=3D nil {
        fmt.Printf("Error reading response body: %v\n", err)
        return
    }

    type OcrResult struct {
        PrunedResult map[string]interface{} `json:"prunedResult"`=20
        OcrImage     *string                `json:"ocrImage"`    =20
    }

    type Response struct {
        Result struct {
